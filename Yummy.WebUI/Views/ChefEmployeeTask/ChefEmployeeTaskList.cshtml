@using Yummy.WebUI.Enums
@using Yummy.WebUI.Extensions
@model PagedChefEmployeeTaskResult

@{
    ViewData["Title"] = "ChefEmployeeTaskList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = (Model.Page - 1) * Model.PageSize + 1;
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12">
                <div class="card">

                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">Çalışan Görevleri</h4>

                        <div class="card-header-action">
                            <a href="/ChefEmployeeTask/Create" class="btn btn-success">
                                <i class="fas fa-plus"></i> Ekle
                            </a>
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="table-responsive">

                            <table class="table table-striped table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th style="width:60px;">#</th>
                                        <th>Şef</th>
                                        <th>Görev</th>
                                        <th>Atama</th>
                                        <th>Bitiş</th>
                                        <th>Öncelik</th>
                                        <th>Durum</th>
                                        <th class="text-right" style="width:200px;"></th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @if (Model.Items == null || !Model.Items.Any())
                                    {
                                        <tr>
                                            <td colspan="8" class="text-center text-muted py-4">
                                                Kayıt bulunamadı.
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var item in Model.Items)
                                        {
                                            <tr>
                                                <td>@count</td>
                                                <td>@item.ChefName</td>
                                                <td>@item.TaskName</td>
                                                <td>@item.AssignDate.ToString("dd.MM.yyyy")</td>
                                                <td>@item.DueDate.ToString("dd.MM.yyyy")</td>

                                                <td>
                                                    @{
                                                        string badgeClass = item.TaskPriority switch
                                                        {
                                                            Priority.High => "badge badge-danger",
                                                            Priority.Low => "badge badge-warning",
                                                            _ => "badge badge-secondary"
                                                        };
                                                    }
                                                    <span class="@badgeClass">
                                                        @item.TaskPriority.GetDisplayName()
                                                    </span>
                                                </td>

                                                <td>
                                                    @if (item.TaskStatus)
                                                    {
                                                        <span class="badge badge-success">Tamamlandı</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-info">Devam Ediyor</span>
                                                    }
                                                </td>

                                                <td class="text-right">
                                                    <a href="/ChefEmployeeTask/Update/@item.Id"
                                                       class="btn btn-info btn-sm">
                                                        Güncelle
                                                    </a>

                                                    <a href="/ChefEmployeeTask/Detail/@item.Id"
                                                       class="btn btn-primary btn-sm">
                                                        Detay
                                                    </a>

                                                    <a href="/ChefEmployeeTask/Delete/@item.Id"
                                                       class="btn btn-danger btn-sm"
                                                       onclick="return confirm('@item.TaskName görevini silmek istediğinize emin misiniz?');">
                                                        Sil
                                                    </a>
                                                </td>
                                            </tr>

                                            count++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <div class="text-muted small">
                                Sayfa @Model.Page / @Model.TotalPages
                            </div>

                            <ul class="pagination mb-0">

                                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                                    <a class="page-link" href="?page=@(Model.Page - 1)">
                                        &laquo;
                                    </a>
                                </li>

                                @{
                                    int total = Model.TotalPages;
                                    int current = Model.Page;

                                    var pages = new List<int>();
                                    pages.Add(1);

                                    for (int p = current - 2; p <= current + 2; p++)
                                    {
                                        if (p > 1 && p < total)
                                            pages.Add(p);
                                    }

                                    if (total > 1)
                                        pages.Add(total);

                                    pages = pages.Distinct().OrderBy(x => x).ToList();

                                    int prev = 0;

                                    foreach (var p in pages)
                                    {
                                        if (prev != 0 && p - prev > 1)
                                        {
                                            <li class="page-item disabled">
                                                <span class="page-link">…</span>
                                            </li>
                                        }

                                        <li class="page-item @(p == current ? "active" : "")">
                                            <a class="page-link" href="?page=@p">@p</a>
                                        </li>

                                        prev = p;
                                    }
                                }

                                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                                    <a class="page-link" href="?page=@(Model.Page + 1)">
                                        &raquo;
                                    </a>
                                </li>

                            </ul>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
