@model ResultContactDto

<section id="contact" class="contact section">

    <div class="container section-title" data-aos="fade-up">
        <h2>İletişim Bilgileri</h2>
        <p><span>Yardıma ihtiyacınız varsa</span> <span class="description-title">Bizimle iletişime geçin</span></p>
    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="mb-5">
            <iframe style="width: 100%; height: 400px;" src="@Model.MapLocation" frameborder="0" allowfullscreen=""></iframe>
        </div>

        <div class="row gy-4">

            <div class="col-md-6">
                <div class="info-item d-flex align-items-center" data-aos="fade-up" data-aos-delay="200">
                    <i class="icon bi bi-geo-alt flex-shrink-0"></i>
                    <div>
                        <h3>Adres</h3>
                        <p>@Model.Address</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="info-item d-flex align-items-center" data-aos="fade-up" data-aos-delay="300">
                    <i class="icon bi bi-telephone flex-shrink-0"></i>
                    <div>
                        <h3>Telefon</h3>
                        <p>@Model.Phone</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="info-item d-flex align-items-center" data-aos="fade-up" data-aos-delay="400">
                    <i class="icon bi bi-envelope flex-shrink-0"></i>
                    <div>
                        <h3>Email</h3>
                        <p>@Model.Email</p>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="info-item d-flex align-items-center" data-aos="fade-up" data-aos-delay="500">
                    <i class="icon bi bi-clock flex-shrink-0"></i>
                    <div>
                        <h3>Açık saatler<br></h3>
                        <p>@Html.Raw(Model.OpenHours)</p>
                    </div>
                </div>
            </div>

        </div>

        @await Html.PartialAsync("~/Views/Message/SendMessage.cshtml", new CreateMessageDto())
    </div>

</section>