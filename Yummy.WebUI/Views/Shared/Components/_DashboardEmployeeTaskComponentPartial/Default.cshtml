@using Yummy.WebUI.Enums
@using Yummy.WebUI.Extensions
@model List<LastTaskSummaryDto>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4>Görev Tablosu</h4>                
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <tr>     
                            <th></th>
                            <th>Görev Adı</th>
                            <th>Görevliler</th>
                            <th>Görev Durumu</th>
                            <th>Atanma Tarihi</th>
                            <th>Son Teslim Tarihi</th>
                            <th>Öncelik Durumu</th>
                            <th></th>
                        </tr>
                        
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-4">
                                    Kayıt bulunamadı.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>     
                                    <td></td>
                                    <td>@item.TaskName</td>
                                    <td class="text-truncate">
                                        <ul class="list-unstyled order-list m-b-0 m-b-0">
                                            @foreach (var chef in item.Chefs)
                                            {
                                                <li class="team-member team-member-sm">
                                                    <img class="rounded-circle"
                                                         src="@chef.ImageUrl" alt="user" data-toggle="tooltip" title=""
                                                         data-original-title="@chef.NameSurname">
                                                </li>
                                            }
         
                                        </ul>
                                    </td>
                                    <td>
                                        @if (item.TaskStatus)
                                        {
                                            <span class="badge badge-success">Tamamlandı</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-info">Devam Ediyor</span>
                                        }
                                    </td>
                                    <td>@item.AssignDate</td>
                                    <td>@item.DueDate</td>
                                    <td>
                                         @{
                                            string badgeClass = item.TaskPriority switch
                                            {
                                                Priority.High => "badge badge-danger",
                                                Priority.Low => "badge badge-warning",
                                                _ => "badge badge-secondary"
                                            };
                                        }
                                        <span class="@badgeClass">
                                            @item.TaskPriority.GetDisplayName()
                                        </span>
                                    </td>
                                    <td><a href="/ChefEmployeeTask/Detail/@item.Id" class="btn btn-outline-primary">Detay</a></td>
                                </tr>
                            }
                        }
                        
                       
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>