@model StatisticsDto

<section id="stats" class="stats section dark-background">

    <img src="/yummy-red-1.0.0/assets/img/stats-bg.jpg" alt="" data-aos="fade-in">

    <div class="container position-relative" data-aos="fade-up" data-aos-delay="100">

        <div class="row gy-4">

            <div class="col-lg-3 col-md-6">
                <div class="stats-item text-center w-100 h-100">
                    <span data-purecounter-start="0" data-purecounter-end="@Model.ProductCount" data-purecounter-duration="1" class="purecounter"></span>
                    <p>
                        @Html.DisplayNameFor(x => x.ProductCount)
                    </p>
                </div>
            </div><!-- End Stats Item -->

            <div class="col-lg-3 col-md-6">
                <div class="stats-item text-center w-100 h-100">
                    <span data-purecounter-start="0" data-purecounter-end="@Model.ChefCount" data-purecounter-duration="1" class="purecounter"></span>
                    <p>@Html.DisplayNameFor(x => x.ChefCount)</p>
                </div>
            </div><!-- End Stats Item -->

            <div class="col-lg-3 col-md-6">
                <div class="stats-item text-center w-100 h-100">
                    <span data-purecounter-start="0" data-purecounter-end="@Model.ReservationCount" data-purecounter-duration="1" class="purecounter"></span>
                    <p>@Html.DisplayNameFor(x => x.ReservationCount)</p>
                </div>
            </div><!-- End Stats Item -->

            <div class="col-lg-3 col-md-6">
                <div class="stats-item text-center w-100 h-100">
                    <span data-purecounter-start="0" data-purecounter-end="@Model.TotalGuestCount" data-purecounter-duration="1" class="purecounter"></span>
                    <p>@Html.DisplayNameFor(x => x.TotalGuestCount)</p>
                </div>
            </div><!-- End Stats Item -->

        </div>

    </div>

</section>