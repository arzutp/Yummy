@using Yummy.WebUI.Enums
@using Yummy.WebUI.Extensions
@model List<ResultGroupReservationDto>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h4>Bugünün Grup Rezervasyonları</h4>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <tr>
                            <th></th>
                            <th>Başlık</th>
                            <th>İletişime Geçilecek Kişi</th>
                            <th>Telefon Numarası</th>
                            <th>Rezervasyon Durumu</th>
                            <th>Kişi Sayısı</th>
                            <th>Son İşlem Tarihi</th>
                            <th>Rezervasyon Tarihi</th>
                            <th>Öncelik</th>
                            <th>Detaylar</th>
                        </tr>
                        @if (Model == null || !Model.Any())
                        {
                            <tr>
                                <td colspan="10" class="text-center text-muted py-4">
                                    Bugün için grup rezervasyonu yok.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td></td>
                                    <td>@item.GroupTitle</td>
                                    <td>@item.ResponsibleCustomerName</td>
                                    <td>@item.PhoneNumber</td>
                                    <td>
                                        @{
                                            string badgeClass = item.Status switch
                                            {
                                                ReservationStatus.Cancel => "badge badge-danger",
                                                ReservationStatus.Wait => "badge badge-warning",
                                                _ => "badge badge-secondary"
                                            };
                                        }
                                        <span class="@badgeClass">
                                            @item.Status.GetDisplayName()
                                        </span>
                                    </td>
                                    <td>@item.PersonCount</td>
                                    <td>@item.LastProcessDate</td>
                                    <td>@item.ReservationDate</td>
                                    <td>
                                        @{
                                            string priorityBadgeClass = item.Priority switch
                                            {
                                                Priority.High => "badge badge-danger",
                                                Priority.Low => "badge badge-warning",
                                                _ => "badge badge-secondary"
                                            };
                                        }
                                        <span class="@priorityBadgeClass">
                                            @item.Priority.GetDisplayName()
                                        </span>
                                    </td>
                                    <td>
                                        <button type="button"
                                                class="btn btn-outline-primary btn-reservation-detail"
                                                data-id="@item.Id">
                                            Detay
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>