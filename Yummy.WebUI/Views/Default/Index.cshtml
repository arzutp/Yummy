@model CreateReservationDto

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

@await Component.InvokeAsync("_HeadDefaultComponentPartial")

<body class="index-page">

    @await Component.InvokeAsync("_NavBarDefaultComponentPartial") 

    <main class="main">

        @await Component.InvokeAsync("_FeatureDefaultComponentPartial")

        @await Component.InvokeAsync("_AboutDefaultComponentPartial")

        @await Component.InvokeAsync("_ServiceDefaultComponentPartial")

        @await Component.InvokeAsync("_HomePageStatisticsComponentPartial")

        @await Component.InvokeAsync("_DefaultMenuViewComponentPartial")

        @await Component.InvokeAsync("_TestimonialDefaultComponentPartial")

        @await Component.InvokeAsync("_SpecialEventDefaultComponentPartial")

        @await Component.InvokeAsync("_ChefDefaultComponentPartial")

        <section id="book-a-table" class="book-a-table section">

            <!-- Section Title -->
            <div class="container section-title" data-aos="fade-up">
                <h2>Rezervasyon</h2>
                <p><span>Sizi ağırlamak</span> <span class="description-title">için buradayız.<br></span></p>
            </div><!-- End Section Title -->

            <div class="container">

                <div class="row g-0" data-aos="fade-up" data-aos-delay="100">

                    <div class="col-lg-4 reservation-img" style="background-image: url(/yummy-red-1.0.0/assets/img/reservation.jpg);"></div>

                    <div class="col-lg-8 d-flex align-items-center reservation-form-bg" data-aos="fade-up" data-aos-delay="200">
                        <form asp-action="Index" asp-controller="Default" method="post" class="php-email-form" data-native-submit="true">
                            <div class="row gy-4">
                                <div class="col-lg-4 col-md-6">
                                    <input type="text" asp-for="Name" class="form-control" id="name" placeholder="Adınız" required="">
                                </div>
                                <div class="col-lg-4 col-md-6">
                                    <input type="text" asp-for="Surname" class="form-control" id="surname" placeholder="Soyadınız" required="">
                                </div>
                                <div class="col-lg-4 col-md-6">
                                    <input type="email" class="form-control" asp-for="Email" id="email" placeholder="Email adresiniz" required="">
                                </div>
                                <div class="col-lg-4 col-md-6">
                                    <input type="text" class="form-control" asp-for="PhoneNumber" id="phone" placeholder="Telefon numaranız" required="">
                                </div>
                                <div class="col-lg-4 col-md-6">
                                    <input type="datetime-local" asp-for="ReservationDate" class="form-control" id="date" placeholder="Tarih" required="">
                                </div>
                                <div class="col-lg-4 col-md-6">
                                    <input type="number" class="form-control" asp-for="CountOfPeople" id="people" placeholder="Kişi Sayısı" required="">
                                </div>
                            </div>

                            <div class="form-group mt-3">
                                <textarea class="form-control" asp-for="Message" rows="5" placeholder="Varsa Mesajınız"></textarea>
                            </div>

                            <div class="text-center mt-3">
                                <div class="loading">Yükleniyor...</div>
                                <div class="error-message"></div>
                                <div class="sent-message">Rezervasyon talebiniz gönderildi. Rezervasyonunuzu onaylamak için sizi arayacağız veya e-posta göndereceğiz. Teşekkürler!</div>
                                <button type="submit">Oluşturun</button>
                            </div>
                        </form>
                    </div><!-- End Reservation Form -->

                </div>

            </div>

        </section><!-- /Book A Table Section -->

        @await Component.InvokeAsync("_HomePageGalleryComponentPartial")

        @await Component.InvokeAsync("_DefaultMenuContactComponentPartial")

    </main>

    @await Component.InvokeAsync("_FooterDefaultComponentPartial")

</body>

</html>

<script>
    document.addEventListener('submit', function (e) {
      const form = e.target;
      if (!form.matches('form.php-email-form[data-native-submit="true"]')) return;

      e.stopImmediatePropagation();
    }, true);
</script>