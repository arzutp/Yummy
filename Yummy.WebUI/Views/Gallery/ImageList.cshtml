@model List<ResultImageDto>

@{
    ViewData["Title"] = "ImageList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    .portfolio-thumb {
        width: 100%;
        height: 300px;
        overflow: hidden;
        border-radius: 12px;
        position: relative;
        background-color: #f2f2f2;
    }

        .portfolio-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .project-title {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 10px;
        font-size: 14px;
        color: #fff;
        background: linear-gradient(transparent, rgba(0,0,0,0.7));
        text-align: center;
    }

    .delete-btn {
        position: absolute;
        top: 10px;
        right: 10px;
        background: rgba(220,53,69,0.9);
        color: white;
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 13px;
        cursor: pointer;
        transition: 0.2s;
    }

        .delete-btn:hover {
            background: rgba(220,53,69,1);
            transform: scale(1.05);
        }

</style>

<section class="section">
    <a href="/Gallery/Create" class="btn btn-success float-right">Ekle</a>
    <br />

    <div class="section-body">
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-body">

                        <section id="portfolio" class="gray-bg padding-top-bottom">
                            <div class="row">
                                @foreach (var item in Model)
                                {
                                    <article class="col-md-4 col-sm-6 mb-4">
                                        <div class="portfolio-thumb">
                                            <img src="@item.Url" alt="@item.Title" />

                                            <span class="project-title">@item.Title</span>

                                            <span class="delete-btn"
                                                  onclick="location.href='/Gallery/Delete/@item.Id'">
                                                Sil
                                            </span>
                                        </div>
                                    </article>

                                }
                            </div>
                        </section>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
