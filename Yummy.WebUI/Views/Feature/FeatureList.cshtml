@model ResultFeatureDto

@{
    ViewData["Title"] = "FeatureList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12 col-md-12 col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h4>Öne Çıkan Alanlar</h4>
                    </div>
                    <div class="card-body">
                        @if (Model is null)
                        {
                            <a href="/Feature/Create" class="btn btn-success float-right">Ekle</a>
                            <br />
                        }
                        <table class="table">
                            <thead>
                                <tr>
                                    <th scope="col">#</th>
                                    <th scope="col">Başlık</th>
                                    <th scope="col">Alt Başlık</th>
                                    <th scope="col"></th>
                                    <th scope="col"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <th scope="row">1</th>
                                    <td>@Model.Title</td>
                                    <td>@Model.SubTitle</td>
                                    <td><a href="/Feature/Delete/@Model.Id" class="btn btn-danger">Sil</a></td>
                                    <td><a href="/Feature/Update/@Model.Id" class="btn btn-info">Güncelle</a></td>
                                </tr>
                                }
                            </tbody>

                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
