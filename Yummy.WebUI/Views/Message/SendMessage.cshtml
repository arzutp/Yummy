@model CreateMessageDto

<form asp-action="SendMessage" method="post" asp-controller="Message" class="php-email-form" data-native-submit="true">
    <div class="row gy-4">

        <div class="col-md-3">
            <input type="text" asp-for="Name" class="form-control" placeholder="Adınız" required="">
        </div>
        <div class="col-md-3">
            <input type="text" asp-for="Surname" class="form-control" placeholder="Soyadınız" required="">
        </div>

        <div class="col-md-6 ">
            <input type="email" class="form-control" asp-for="Email" placeholder="Email adresiniz" required="">
        </div>

        <div class="col-md-12">
            <input type="text" class="form-control" asp-for="Subject" placeholder="Konu" required="">
        </div>

        <div class="col-md-12">
            <textarea class="form-control" asp-for="Detail" rows="6" placeholder="Mesajınız" required=""></textarea>
        </div>

        <div class="col-md-12 text-center">
            <div class="loading">Loading</div>
              <div class="error-message"></div>
              <div class="sent-message">Your message has been sent. Thank you!</div>

            <button type="submit">Gönder</button>
        </div>

    </div>
</form>

<script>
    document.addEventListener('submit', function (e) {
      const form = e.target;
      if (!form.matches('form.php-email-form[data-native-submit="true"]')) return;

      e.stopImmediatePropagation();
    }, true);
</script>
