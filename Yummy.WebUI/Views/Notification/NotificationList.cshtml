@model PagedNotificationResult

@{
    ViewData["Title"] = "NotificationList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = (Model.Page - 1) * Model.PageSize + 1;
}

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12">
                <div class="card">

                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">Bildirimler</h4>

                        <div class="card-header-action">
                            <a href="/Notification/Create" class="btn btn-success">
                                <i class="fas fa-plus"></i> Ekle
                            </a>
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th style="width:60px;">#</th>
                                        <th>Başlık</th>
                                        <th style="min-width:260px;">Konu</th>
                                        <th style="width:160px;">Tarih</th>
                                        <th class="text-right" style="width:260px;"></th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @if (Model.Items == null || !Model.Items.Any())
                                    {
                                        <tr>
                                            <td colspan="5" class="text-center text-muted py-4">
                                                Kayıt bulunamadı.
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var item in Model.Items)
                                        {
                                            <tr>
                                                <td>@count</td>

                                                <td>
                                                    <div class="font-weight-600">@item.Title</div>
                                                    <div class="text-muted small">#@item.Id</div>
                                                </td>

                                                <td>
                                                    <div class="text-truncate" style="max-width: 380px;">
                                                        @item.Description
                                                    </div>
                                                </td>

                                                <td>@item.DateTime.ToString("dd MMMM yyyy")</td>

                                                <td class="text-right">

                                                    <a href="/Notification/Detail/@item.Id" class="btn btn-info btn-sm">
                                                        Detay
                                                    </a>

                                                    <a href="/Notification/Delete/@item.Id"
                                                       class="btn btn-danger btn-sm"
                                                       onclick="return confirm('Bu bildirimi silmek istediğine emin misin?');">
                                                        Sil
                                                    </a>

                                                </td>
                                            </tr>

                                            count++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        @if (Model.TotalPages > 1)
                        {
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <div class="text-muted small">
                                    Sayfa @Model.Page / @Model.TotalPages
                                </div>

                                <ul class="pagination mb-0">
                                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                                        <a class="page-link" href="?page=@(Model.Page - 1)" aria-label="Previous">
                                            <span aria-hidden="true">&laquo;</span>
                                        </a>
                                    </li>

                                    @{
                                        int total = Model.TotalPages;
                                        int current = Model.Page;

                                        var pages = new List<int>();
                                        pages.Add(1);

                                        for (int p = current - 2; p <= current + 2; p++)
                                        {
                                            if (p > 1 && p < total) pages.Add(p);
                                        }

                                        if (total > 1) pages.Add(total);

                                        pages = pages.Distinct().OrderBy(x => x).ToList();

                                        int prev = 0;
                                        foreach (var p in pages)
                                        {
                                            if (prev != 0 && p - prev > 1)
                                            {
                                                <li class="page-item disabled">
                                                    <span class="page-link">…</span>
                                                </li>
                                            }

                                            <li class="page-item @(p == current ? "active" : "")">
                                                <a class="page-link" href="?page=@p">@p</a>
                                            </li>

                                            prev = p;
                                        }
                                    }

                                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                                        <a class="page-link" href="?page=@(Model.Page + 1)" aria-label="Next">
                                            <span aria-hidden="true">&raquo;</span>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>
