@model GetByIdNotificationDto

@{
    ViewData["Title"] = "Bildirim Detayı";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<section class="section">
    <div class="section-body">
        <div class="row justify-content-center">
            <div class="col-12 col-lg-8">
                <div class="card shadow-sm border-0">

                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-3">
                            @if (!string.IsNullOrEmpty(Model.IconUrl))
                            {
                                <img src="@Model.IconUrl" alt="icon" width="40" height="40" />
                            }
                            <div>
                                <h5 class="mb-0 fw-semibold">@Model.Title</h5>
                                <small class="text-muted">
                                    @Model.DateTime.ToString("dd MMMM yyyy HH:mm")
                                </small>
                            </div>
                        </div>

                        @if (Model.IsRead)
                        {
                            <span class="badge bg-success">Okundu</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Okunmadı</span>
                        }
                    </div>

                    <div class="card-body">
                        <div class="p-3 rounded bg-light">
                            <p class="mb-0" style="line-height:1.7;">
                                @Model.Description
                            </p>
                        </div>
                    </div>

                    <div class="card-footer bg-white text-end">
                        <a asp-action="NotificationList" class="btn btn-outline-secondary">
                            ← Geri Dön
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>
